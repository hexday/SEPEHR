# SEPEHR — Environment Variables Template
# Copy this to .env and fill in all values before deployment.
# NEVER commit .env to version control.

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=SEPEHR
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# CRITICAL: Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX_64

# Comma-separated list of allowed CORS origins (no trailing slash)
# Example: https://sepehr.example.ir,https://www.sepehr.example.ir
CORS_ORIGINS=https://sepehr.example.ir

# Your domain name (used by Nginx for SSL cert path)
DOMAIN=sepehr.example.ir

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=sepehr
POSTGRES_USER=sepehr
# CRITICAL: Use a strong password (min 32 chars)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://sepehr:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/sepehr

# ── Redis ─────────────────────────────────────────────────────────────────────
# CRITICAL: Use a strong password
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/2

# ── MinIO Object Storage ──────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
# CRITICAL: Use strong credentials (min 20 chars for secret)
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY_MIN_20_CHARS
MINIO_BUCKET_MEDIA=sepehr-media
MINIO_BUCKET_VOICE=sepehr-voice
MINIO_BUCKET_FILES=sepehr-files
MINIO_SECURE=false

# ── Admin Account ─────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# CRITICAL: Must be changed immediately after first login
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD_MIN_16_CHARS

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Frontend Public Variables ─────────────────────────────────────────────────
# These are embedded at build time
NEXT_PUBLIC_API_URL=https://sepehr.example.ir
NEXT_PUBLIC_WS_URL=wss://sepehr.example.ir
NEXT_PUBLIC_MINIO_HOST=sepehr.example.ir
NEXT_PUBLIC_MINIO_PORT=443

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_UPLOAD=30/minute

# ── File Upload Limits ────────────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10
MAX_VOICE_SIZE_MB=25
MAX_FILE_SIZE_MB=50

# ── Argon2 Tuning (do not change in production after first use) ────────────────
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# ── Monitoring (optional — change these) ──────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
